/* 月视图 - iOS 26 Liquid Glass */
.page-wrap {
  min-height: 100vh;
  padding: 20rpx 24rpx 160rpx;
  padding-left: calc(24rpx + env(safe-area-inset-left));
  padding-right: calc(24rpx + env(safe-area-inset-right));
  box-sizing: border-box;
}

/* Month header */
.month-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  will-change: transform, opacity;
}
.nav-arrow {
  font-size: 52rpx;
  font-weight: 300;
  color: #007AFF;
  padding: 0 20rpx;
  line-height: 1;
}
.month-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1C1C1E;
  letter-spacing: 0.03em;
}

/* Scope bar */
.scope-bar {
  padding: 8rpx 8rpx 12rpx;
}
.scope-text {
  font-size: 22rpx;
}

.top-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.share-entry {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 18rpx;
  transition: transform 0.18s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.18s ease;
}
.share-entry:active {
  transform: translateY(1rpx) scale(0.97);
}

/* Weekday row */
.weekday-row {
  display: flex;
  padding: 12rpx 0 8rpx;
}
.weekday {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  font-weight: 600;
  color: #8E8E93;
  text-transform: uppercase;
}

/* Calendar grid */
.calendar-grid {
  display: flex;
  flex-wrap: wrap;
}
.day-cell {
  width: 14.28%;
  flex: 0 0 14.28%;
  box-sizing: border-box;
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  border-radius: 18rpx;
  transition: transform 0.16s cubic-bezier(0.22, 1, 0.36, 1), background 0.2s ease, opacity 0.16s ease;
}
.day-cell:active:not(.empty) {
  transform: scale(0.92);
}
.day-cell.empty {
  visibility: hidden;
}
.day-num {
  font-size: 30rpx;
  font-weight: 500;
  color: #1C1C1E;
  line-height: 1;
}

/* Today ring */
.day-cell.today {
  background: rgba(0, 122, 255, 0.1);
  border: 2rpx solid rgba(0, 122, 255, 0.35);
}
.day-cell.today .day-num {
  color: #007AFF;
  font-weight: 700;
}

/* Has-class dot */
.day-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #007AFF;
}
.day-cell.has-class .day-num {
  font-weight: 600;
  color: #007AFF;
}

.day-cell.has-class {
  box-shadow: inset 0 0 0 1rpx rgba(0, 122, 255, 0.12);
}

.import-sheet {
  max-height: 84vh;
}

.import-textarea {
  margin-top: 12rpx;
  width: 100%;
  min-height: 260rpx;
  max-height: 420rpx;
  border-radius: 20rpx;
  padding: 20rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(60, 60, 67, 0.14);
  color: #1C1C1E;
  font-size: 24rpx;
  line-height: 1.5;
}

.import-placeholder {
  color: #8E8E93;
}

.import-actions {
  margin-top: 18rpx;
  display: flex;
  gap: 14rpx;
}

.import-btn-cancel,
.import-btn-confirm {
  flex: 1;
}
