.page-wrap {
  min-height: 100vh;
  padding: 24rpx;
  padding-left: calc(24rpx + env(safe-area-inset-left));
  padding-right: calc(24rpx + env(safe-area-inset-right));
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero {
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1c1c1e;
  margin-bottom: 12rpx;
}

.hint {
  line-height: 1.45;
}

.search-bar {
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.search-input {
  display: block;
  width: 100%;
  box-sizing: border-box;
  min-height: 80rpx;
  padding: 20rpx 22rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  color: #1c1c1e;
  background: rgba(0, 0, 0, 0.06);
}

.search-placeholder {
  color: #aeaeb2;
  font-size: 26rpx;
}

.empty {
  padding: 48rpx 24rpx;
  text-align: center;
}

.list {
  padding: 8rpx 0;
  margin-bottom: 28rpx;
}

.stu-row {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
  gap: 20rpx;
}

.stu-row:last-child {
  border-bottom: none;
}

.stu-row:active {
  opacity: 0.88;
}

.color-bar {
  width: 8rpx;
  align-self: stretch;
  min-height: 72rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.stu-main {
  flex: 1;
  min-width: 0;
}

.stu-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1c1c1e;
  display: block;
}

.stu-meta {
  margin-top: 6rpx;
  display: block;
}

.stu-edit {
  font-size: 26rpx;
  color: #007aff;
  flex-shrink: 0;
}

.add-btn {
  text-align: center;
  padding: 28rpx 24rpx;
  font-size: 30rpx;
  font-weight: 600;
}

/* 表单弹层 */
.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.38);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 48rpx 24rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.modal-card {
  width: 100%;
  max-width: 680rpx;
  max-height: 85vh;
  overflow-y: auto;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 20rpx;
  padding: 32rpx 28rpx 28rpx;
  box-shadow: 0 -8rpx 48rpx rgba(0, 0, 0, 0.12);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1c1c1e;
  margin-bottom: 28rpx;
  text-align: center;
}

.modal-field {
  margin-bottom: 28rpx;
}

/* 竖排 label + input：避免真机 input 行高过小导致占位符与文字堆叠 */
.modal-field--input {
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.modal-field.row-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.modal-label {
  font-size: 26rpx;
  color: #8e8e93;
  display: block;
  margin-bottom: 14rpx;
  line-height: 1.35;
}

.modal-field.row-picker .modal-label {
  margin-bottom: 0;
  flex-shrink: 0;
}

.modal-input {
  display: block;
  width: 100%;
  min-height: 96rpx;
  padding: 22rpx 24rpx;
  border-radius: 14rpx;
  font-size: 30rpx;
  line-height: 44rpx;
  color: #1c1c1e;
  background: rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
  /* 部分机型需固定高度，避免 placeholder 与 value 同一行重复绘制 */
  height: 96rpx;
}

.modal-placeholder {
  color: #aeaeb2;
  font-size: 26rpx;
  line-height: 40rpx;
}

.picker-val {
  font-size: 28rpx;
  color: #007aff;
  text-align: right;
  flex: 1;
}

.modal-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
  justify-content: flex-end;
}

.modal-btn {
  padding: 22rpx 36rpx;
  font-size: 28rpx;
}

.modal-btn.primary {
  min-width: 160rpx;
  text-align: center;
}
