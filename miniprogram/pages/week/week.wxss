/* 周视图 - iOS 26 Liquid Glass */
.page-wrap {
  min-height: 100vh;
  padding: 20rpx 24rpx 160rpx;
  padding-left: calc(24rpx + env(safe-area-inset-left));
  padding-right: calc(24rpx + env(safe-area-inset-right));
  box-sizing: border-box;
}

.week-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  margin-bottom: 12rpx;
  will-change: transform, opacity;
}
.nav-arrow {
  font-size: 52rpx;
  font-weight: 300;
  color: #007AFF;
  padding: 0 20rpx;
  line-height: 1;
}
.week-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1C1C1E;
  letter-spacing: 0.02em;
}

.top-actions {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 12rpx;
}

.share-entry {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 18rpx;
  transition: transform 0.18s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.18s ease;
}
.share-entry:active {
  transform: translateY(1rpx) scale(0.97);
}

.week-scroll {
  height: calc(100vh - 260rpx);
}
.week-list {
  padding-bottom: 24rpx;
}

/* Day block */
.day-block {
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.2s ease;
}
.day-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}
.day-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #3A3A3C;
}
.day-label.today {
  color: #007AFF;
}
.day-entry {
  font-size: 24rpx;
  color: #007AFF;
  font-weight: 500;
}

/* Course card */
.course-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.course-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  gap: 16rpx;
  transition: transform 0.16s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.16s ease;
}
.course-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.08);
}
.course-color-bar {
  width: 6rpx;
  height: 56rpx;
  border-radius: 3rpx;
  background: var(--accent, #A8C5C0);
  flex-shrink: 0;
}
.course-body {
  flex: 1;
  min-width: 0;
}
.course-time {
  display: block;
  font-size: 24rpx;
  color: #8E8E93;
  font-weight: 500;
  margin-bottom: 2rpx;
}
.course-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1C1C1E;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.course-dur {
  font-size: 22rpx;
  color: #8E8E93;
  font-weight: 500;
  flex-shrink: 0;
}

.no-class {
  padding: 20rpx 0;
  color: #8E8E93;
}
