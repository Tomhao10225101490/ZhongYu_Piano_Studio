.page-wrap {
  min-height: 100vh;
  padding: 24rpx;
  padding-left: calc(24rpx + env(safe-area-inset-left));
  padding-right: calc(24rpx + env(safe-area-inset-right));
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero {
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
}

.boss-exp-hint {
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  border-left: 6rpx solid rgba(0, 122, 255, 0.55);
}

.boss-exp-hint .text-caption {
  line-height: 1.45;
  color: #3a3a3c;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1c1c1e;
  margin-bottom: 12rpx;
}

.hint {
  line-height: 1.45;
}

.summary-strip {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 16rpx;
}

.summary-strip-text {
  flex: 1;
  min-width: 0;
}

.summary-main {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1c1c1e;
  line-height: 1.35;
}

.summary-sub {
  display: block;
  margin-top: 8rpx;
  line-height: 1.35;
}

.summary-btn {
  flex-shrink: 0;
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  border-radius: 18rpx;
  font-weight: 600;
}

.filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 22rpx;
  margin-bottom: 16rpx;
  gap: 16rpx;
}

.filter-label {
  font-size: 26rpx;
  color: #8e8e93;
  flex-shrink: 0;
}

.filter-picker-val {
  font-size: 28rpx;
  font-weight: 600;
  color: #007aff;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  min-height: 72rpx;
  padding: 16rpx 18rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  background: rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.search-placeholder {
  color: #aeaeb2;
  font-size: 26rpx;
}

.search-clear {
  flex-shrink: 0;
  color: #007aff;
  padding: 8rpx 4rpx;
}

.groups-wrap {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.month-group {
  padding: 8rpx 0 4rpx;
  overflow: hidden;
}

.group-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12rpx;
  padding: 18rpx 24rpx 12rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.group-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1c1c1e;
}

.group-meta {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #c45c7a;
  font-weight: 600;
}

.empty {
  padding: 48rpx 24rpx;
  text-align: center;
}

.exp-row {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
  gap: 20rpx;
}

.exp-row:last-child {
  border-bottom: none;
}

.exp-row:active {
  opacity: 0.88;
}

.exp-bar {
  width: 8rpx;
  align-self: stretch;
  min-height: 72rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background: linear-gradient(180deg, #c45c7a 0%, #e8a0b0 100%);
}

.exp-main {
  flex: 1;
  min-width: 0;
}

.exp-note {
  font-size: 28rpx;
  font-weight: 600;
  color: #1c1c1e;
  display: block;
}

.exp-amt {
  font-size: 28rpx;
  font-weight: 700;
  color: #c45c7a;
  flex-shrink: 0;
}

.add-btn {
  text-align: center;
  padding: 28rpx 24rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.38);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.modal-card {
  width: 100%;
  max-width: 640rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 32rpx 28rpx 28rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.18);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1c1c1e;
  margin-bottom: 24rpx;
}

.modal-field {
  margin-bottom: 22rpx;
}

.modal-field--input .modal-label {
  display: block;
  font-size: 26rpx;
  color: #8e8e93;
  margin-bottom: 10rpx;
}

.modal-input {
  width: 100%;
  box-sizing: border-box;
  min-height: 80rpx;
  padding: 20rpx 22rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  background: rgba(0, 0, 0, 0.06);
}

.modal-placeholder {
  color: #aeaeb2;
}

.row-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.row-picker .modal-label {
  font-size: 26rpx;
  color: #8e8e93;
  flex-shrink: 0;
}

.modal-picker-val {
  font-size: 28rpx;
  font-weight: 600;
  color: #007aff;
}

.modal-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
  justify-content: flex-end;
}

.modal-btn {
  padding: 18rpx 28rpx;
  font-size: 28rpx;
  border-radius: 18rpx;
  min-width: 120rpx;
  text-align: center;
}

.modal-btn.ghost {
  margin-right: auto;
  color: #ff3b30;
  background: rgba(255, 59, 48, 0.08);
}

.modal-btn.primary {
  font-weight: 700;
}

.modal-quick {
  margin: -6rpx 0 18rpx;
  line-height: 1.45;
}

.modal-quick-link {
  color: #007aff;
  text-decoration: underline;
  text-underline-offset: 4rpx;
}
