/* 设置详情 - iOS 26 Liquid Glass */
.page-wrap {
  min-height: 100vh;
  padding: 20rpx 24rpx 40rpx;
  padding-left: calc(24rpx + env(safe-area-inset-left));
  padding-right: calc(24rpx + env(safe-area-inset-right));
  box-sizing: border-box;
}
.card {
  padding: 24rpx 28rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1C1C1E;
  margin-bottom: 8rpx;
}
.row {
  display: flex;
  align-items: center;
  padding: 26rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}
.row:last-of-type {
  border-bottom: none;
}
.label {
  flex: 1;
  color: #3A3A3C;
  font-size: 28rpx;
  font-weight: 500;
}
.input {
  width: 200rpx;
  text-align: right;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: rgba(0, 0, 0, 0.04);
  font-size: 28rpx;
}
.picker-val {
  color: #007AFF;
  font-size: 28rpx;
  font-weight: 600;
}
.save-btn {
  margin-top: 28rpx;
  text-align: center;
  padding: 24rpx;
}

.nav-row {
  justify-content: space-between;
}

.nav-arrow {
  color: #C0C4CC;
  font-size: 30rpx;
  font-weight: 500;
}

.bg-row {
  flex-direction: column;
  align-items: stretch;
  gap: 16rpx;
  padding-bottom: 20rpx;
}

.bg-col .label {
  display: block;
}

.bg-hint {
  display: block;
  margin-top: 6rpx;
  line-height: 1.4;
}

.bg-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex-wrap: wrap;
}

.bg-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  background: rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

.bg-thumb--empty {
  border-style: dashed;
}

.bg-btns {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: 1;
  min-width: 200rpx;
}

.boss-cert-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.boss-cert-sub {
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.35;
}

.boss-open-row {
  margin-top: 0;
}

.bg-pick-btn,
.bg-clear-btn {
  padding: 18rpx 24rpx;
  font-size: 26rpx;
  text-align: center;
}

.bg-clear-btn {
  color: #ff3b30;
  background: rgba(255, 59, 48, 0.08);
  border-color: rgba(255, 59, 48, 0.2);
}
