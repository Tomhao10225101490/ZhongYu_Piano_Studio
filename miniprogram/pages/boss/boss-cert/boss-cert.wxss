.page-wrap {
  min-height: 100vh;
  padding: 24rpx;
  padding-left: calc(24rpx + env(safe-area-inset-left));
  padding-right: calc(24rpx + env(safe-area-inset-right));
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.card {
  padding: 36rpx 32rpx;
}

.status-block {
  margin-bottom: 36rpx;
}

.status-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1c1c1e;
  margin-bottom: 16rpx;
}

.status-desc {
  display: block;
  line-height: 1.5;
  color: #8e8e93;
}

.field-label {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #3a3a3c;
  margin-bottom: 20rpx;
}

.code-input-wrap {
  position: relative;
  z-index: 2;
  isolation: isolate;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.85);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  margin-bottom: 40rpx;
}

.code-input {
  display: block;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #1c1c1e;
}

.foot-btn {
  text-align: center;
  padding: 24rpx;
}

.foot-btn--spaced {
  margin-top: 20rpx;
}

.exit-boss-btn {
  color: #ff3b30;
  background: rgba(255, 59, 48, 0.08);
  border: 1rpx solid rgba(255, 59, 48, 0.25);
}
