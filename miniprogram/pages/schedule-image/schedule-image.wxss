/* 课表图片页 */
.page-wrap {
  min-height: 100vh;
  padding: 24rpx;
  padding-left: calc(24rpx + env(safe-area-inset-left));
  padding-right: calc(24rpx + env(safe-area-inset-right));
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.title-wrap {
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
}

/* 支持按日切换时：左右为切换按钮，中间标题居中 */
.title-wrap--nav {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.title-center {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.day-nav-btn {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(0, 122, 255, 0.09);
  border: 1rpx solid rgba(0, 122, 255, 0.20);
  transition: opacity 0.15s ease, transform 0.15s ease;
}

.day-nav-btn--active {
  opacity: 0.6;
  transform: scale(0.94);
}

.day-nav-arrow {
  font-size: 36rpx;
  line-height: 1;
  font-weight: 600;
  color: #007aff;
}

.day-nav-label {
  font-size: 22rpx;
  color: #007aff;
  white-space: nowrap;
}

.page-title {
  font-family: "PingFang SC", -apple-system, sans-serif;
  font-size: 34rpx;
  font-weight: 600;
  color: #1C1C1E;
  display: block;
}

.page-subtitle {
  font-size: 26rpx;
  color: #8E8E93;
  margin-top: 8rpx;
  display: block;
}

.canvas-wrap {
  margin: 0 auto 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.schedule-canvas {
  display: block;
}

.tip {
  text-align: center;
  padding: 24rpx;
}

.preview-wrap {
  margin-top: 24rpx;
}

.preview-img {
  width: 100%;
  border-radius: 20rpx;
  display: block;
  background: #f5f5f5;
}

.btn-row {
  display: flex;
  gap: 24rpx;
  margin-top: 24rpx;
}

.btn-row .glass-btn {
  flex: 1;
  text-align: center;
  padding: 28rpx;
}

.btn-row--forward {
  margin-top: 20rpx;
}

.btn-row--forward .glass-btn {
  flex: none;
  width: 100%;
}

/* 转发：与主按钮区分，轻量微信绿点缀，仍保持玻璃质感 */
.glass-btn-forward {
  background: linear-gradient(
    135deg,
    rgba(7, 193, 96, 0.14) 0%,
    rgba(255, 255, 255, 0.52) 48%,
    rgba(0, 122, 255, 0.06) 100%
  );
  border: 1rpx solid rgba(7, 193, 96, 0.38);
  color: #05945c;
  font-weight: 600;
  box-shadow: 0 4rpx 18rpx rgba(7, 193, 96, 0.12);
}

.glass-btn-forward:active {
  opacity: 0.9;
  transform: scale(0.985);
}
