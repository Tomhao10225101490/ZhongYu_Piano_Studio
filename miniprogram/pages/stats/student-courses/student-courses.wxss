.page-wrap {
  min-height: 100vh;
  padding: 24rpx;
  padding-left: calc(24rpx + env(safe-area-inset-left));
  padding-right: calc(24rpx + env(safe-area-inset-right));
  padding-bottom: 32rpx;
  box-sizing: border-box;
}

.hero {
  padding: 28rpx 26rpx;
  margin-bottom: 20rpx;
}

.hero-name {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1c1c1e;
  margin-bottom: 8rpx;
}

.hero-sub {
  display: block;
  margin-top: 6rpx;
}

.filter-hint {
  color: #007aff;
  font-weight: 600;
}

.filter-bar {
  padding: 20rpx 22rpx;
  margin-bottom: 20rpx;
}

.filter-label {
  display: block;
  margin-bottom: 14rpx;
  color: #8e8e93;
  letter-spacing: 0.02em;
}

.filter-seg {
  display: flex;
  gap: 12rpx;
}

.filter-pill {
  flex: 1;
  text-align: center;
  padding: 18rpx 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #8e8e93;
  border-radius: 20rpx;
  background: rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  transition: color 0.2s, background 0.2s, border-color 0.2s;
}

.filter-pill--active {
  color: #007aff;
  background: rgba(0, 122, 255, 0.1);
  border-color: rgba(0, 122, 255, 0.28);
}

.detail-date-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.pending-tag {
  font-size: 20rpx;
  font-weight: 700;
  color: #ff9500;
  background: rgba(255, 149, 0, 0.12);
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.detail-list {
  padding: 20rpx;
}

.detail-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 20rpx 22rpx 24rpx;
  margin-bottom: 14rpx;
  border-left: 6rpx solid #a8c5c0;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.55);
}

.detail-card:last-child {
  margin-bottom: 0;
}

.detail-main {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.detail-date {
  font-size: 28rpx;
  font-weight: 700;
  color: #1c1c1e;
}

.detail-time {
  font-size: 25rpx;
  color: #3a3a3c;
}

.detail-share {
  font-size: 22rpx;
  color: #8e8e93;
}

.detail-fee {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.detail-fee-boss {
  font-size: 25rpx;
  color: #05945c;
  font-weight: 700;
}

.detail-fee-teacher {
  font-size: 24rpx;
  color: #007aff;
  font-weight: 600;
}

.empty {
  padding: 38rpx 20rpx;
  text-align: center;
}
