/* 统计页 - iOS 风格；适配安全区与宽度不溢出 */
.page-wrap {
  min-height: 100vh;
  padding: 24rpx;
  padding-left: calc(24rpx + env(safe-area-inset-left));
  padding-right: calc(24rpx + env(safe-area-inset-right));
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

.stats-hero {
  padding: 28rpx 28rpx 20rpx;
  margin-bottom: 20rpx;
  will-change: transform, opacity;
}

.stats-hero-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.stats-hero-head .ios-section-title {
  margin-bottom: 0;
  flex: 1;
  min-width: 0;
}

.share-entry {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 18rpx;
  transition: transform 0.18s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.18s ease;
}

.share-entry:active {
  transform: translateY(1rpx) scale(0.97);
}

.anchor-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.anchor-picker {
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  border-radius: 18rpx;
}

.anchor-reset {
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  border-radius: 18rpx;
  color: #007aff;
}

.quick-switch-row {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.quick-switch-btn {
  flex: 1;
  min-width: 0;
  text-align: center;
  padding: 12rpx 0;
  font-size: 24rpx;
  border-radius: 18rpx;
}

.card {
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
  max-width: 100%;
  transition: transform 0.22s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.22s ease;
}

.period-grid {
  display: flex;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.period-card {
  flex: 1;
  min-width: 0;
  padding: 20rpx 18rpx;
  transition: transform 0.18s cubic-bezier(0.22, 1, 0.36, 1), border-color 0.22s ease, opacity 0.18s ease;
}

.period-card--active {
  border-color: rgba(0, 122, 255, 0.42);
  box-shadow:
    0 4rpx 16rpx rgba(0, 122, 255, 0.14),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
}

.period-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1c1c1e;
}

.period-subtitle {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
}

.period-total {
  display: block;
  margin-top: 14rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #007aff;
  line-height: 1.2;
}

.period-mini {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.35;
}

.year-summary {
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: 22rpx;
  box-sizing: border-box;
}

.year-summary-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.year-summary-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.year-share-btn {
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  border-radius: 18rpx;
  font-weight: 600;
  color: #007aff;
}

.year-summary-titles {
  flex: 1;
  min-width: 0;
}

.year-summary-title {
  margin-bottom: 8rpx;
}

.year-summary-sub {
  display: block;
  line-height: 1.4;
}

.year-picker-btn {
  flex-shrink: 0;
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  border-radius: 18rpx;
  font-weight: 600;
  color: #007aff;
}

.year-summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.year-summary-row .label {
  font-size: 26rpx;
  color: #3a3a3c;
  max-width: 62%;
}

.year-summary-row .value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1c1c1e;
}

.year-summary-row--expense {
  padding-top: 20rpx;
}

.expense-value {
  color: #c45c7a;
}

.year-summary-divider {
  height: 1rpx;
  background: rgba(0, 0, 0, 0.08);
  margin: 12rpx 0 8rpx;
}

.net-value {
  font-size: 30rpx;
  color: #1c1c1e;
}

.net-boss {
  color: #05945c;
}

.net-teacher {
  color: #007aff;
}

.year-manage-btn {
  margin-top: 20rpx;
  text-align: center;
  padding: 22rpx 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 20rpx;
}

.year-summary-footnote {
  display: block;
  padding: 16rpx 0 8rpx;
  line-height: 1.45;
  color: #8e8e93;
}

.card-title {
  font-family: "PingFang SC", -apple-system, sans-serif;
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1C1E;
  letter-spacing: 0.02em;
  margin-bottom: 24rpx;
}

.card-subtitle {
  margin-top: -10rpx;
  margin-bottom: 18rpx;
}

.stat-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.stat-row:last-child {
  border-bottom: none;
}

.stat-row .label {
  font-size: 28rpx;
  color: #3A3A3C;
}

.stat-row .value {
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1C1E;
}

.stat-row .value.highlight {
  color: #007AFF;
  font-size: 34rpx;
}

/* 课时费明细卡片列表 */
.detail-list {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.student-count-list {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.student-count-empty {
  padding: 8rpx 0 2rpx;
}

.student-count-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.student-count-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 18rpx;
}

.student-count-left {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 12rpx;
}

.student-count-dot {
  width: 10rpx;
  height: 34rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.student-count-name {
  font-size: 27rpx;
  color: #1c1c1e;
  font-weight: 600;
}

.student-count-num {
  font-size: 26rpx;
  color: #007aff;
  font-weight: 700;
}

.detail-empty {
  margin-top: 22rpx;
  text-align: center;
  padding: 20rpx 0 6rpx;
}

.detail-section-title {
  font-family: "PingFang SC", -apple-system, sans-serif;
  font-size: 26rpx;
  font-weight: 600;
  color: #8E8E93;
  margin-bottom: 16rpx;
}

.detail-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx 24rpx 28rpx;
  margin-bottom: 16rpx;
  border-left: 6rpx solid #A8C5C0;
  transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.2s ease;
}

.detail-card:last-child {
  margin-bottom: 0;
}

.detail-card:active {
  transform: scale(0.99);
  opacity: 0.95;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.07);
}

.detail-main {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.detail-date {
  font-family: "PingFang SC", -apple-system, sans-serif;
  font-size: 28rpx;
  font-weight: 600;
  color: #1C1C1E;
}

.detail-time {
  font-size: 26rpx;
  color: #3A3A3C;
  font-weight: 500;
}

.detail-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #007AFF;
}

.detail-share {
  font-size: 22rpx;
  color: #8e8e93;
  line-height: 1.35;
  margin-top: 2rpx;
}

.detail-fee {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.boss-value {
  color: #05945c;
}

.teacher-value {
  color: #007AFF;
}

.detail-fee-boss {
  font-family: "PingFang SC", -apple-system, sans-serif;
  font-size: 26rpx;
  font-weight: 700;
  color: #05945c;
}

.detail-fee-teacher {
  font-family: "PingFang SC", -apple-system, sans-serif;
  font-size: 24rpx;
  font-weight: 600;
  color: #007AFF;
  opacity: 0.95;
}

.hint {
  padding: 24rpx 0;
  text-align: center;
}

.sheet-section-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #8e8e93;
  padding: 12rpx 8rpx 8rpx;
  letter-spacing: 0.02em;
}
