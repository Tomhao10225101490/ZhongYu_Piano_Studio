.logs-page {
  min-height: 100vh;
  padding: 24rpx;
  padding-left: calc(24rpx + env(safe-area-inset-left));
  padding-right: calc(24rpx + env(safe-area-inset-right));
  box-sizing: border-box;
}

.logs-card {
  padding: 28rpx;
}

.scrollarea {
  max-height: 72vh;
}

.log-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.log-item:last-child {
  border-bottom: none;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
}

.log-index {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(0, 122, 255, 0.1);
  color: #007AFF;
  font-size: 22rpx;
}

.log-date {
  color: #3A3A3C;
  font-size: 26rpx;
}
